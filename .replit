modules = ["php-8.2", "nodejs-20", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 3306
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[[ports]]
localPort = 5002
externalPort = 3002

[[ports]]
localPort = 5003
externalPort = 4200

[[ports]]
localPort = 5004
externalPort = 5000

[[ports]]
localPort = 5005
externalPort = 5173

[[ports]]
localPort = 5006
externalPort = 6000

[[ports]]
localPort = 6379
externalPort = 80

[userenv]

[userenv.shared]
APP_NAME = "Luck2x"
APP_ENV = "local"
APP_DEBUG = "true"
APP_URL = "http://localhost"
LOG_CHANNEL = "stack"
DB_CONNECTION = "mysql"
DB_HOST = "127.0.0.1"
DB_PORT = "3306"
DB_SOCKET = "/tmp/mysql.sock"
DB_DATABASE = "luck2x"
DB_USERNAME = "luck2x"
DB_PASSWORD = "luck2x_pass"
BROADCAST_DRIVER = "log"
CACHE_DRIVER = "file"
QUEUE_CONNECTION = "sync"
SESSION_DRIVER = "file"
SESSION_LIFETIME = "120"
REDIS_HOST = "127.0.0.1"
REDIS_PASSWORD = "null"
REDIS_PORT = "6379"
APP_KEY = "base64:0Xjq/GGC+V6qPt/OuUV/dMnjEcWu53vOBQiQcQFRXXw="

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
